# ============================================
# Stage 1: Build the ChatGPT app artifacts
# ============================================
FROM node:20-slim AS builder

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

COPY package.json pnpm-lock.yaml ./

RUN pnpm install --frozen-lockfile

COPY . .

RUN pnpm chatgpt:build

# ============================================
# Stage 2: Run the MCP server
# ============================================
FROM node:20-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=8787
ENV MCP_PATH=/mcp

COPY --from=builder /app/chatgpt/dist ./chatgpt/dist

EXPOSE 8787

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:' + (process.env.PORT || '8787') + '/healthz').then((res) => { if (!res.ok) process.exit(1) }).catch(() => process.exit(1))"

CMD ["node", "chatgpt/dist/server/index.js"]
