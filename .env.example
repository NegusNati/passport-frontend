# ==============================================
# Frontend Build-Time Environment Variables
# ==============================================
# These are baked into the bundle at build time via Dockerfile ARG

# API base URL (backend API endpoint)
VITE_API_BASE_URL=https://api.passport.et

# Public site URL (used for canonical URLs, Open Graph, etc.)
VITE_SITE_URL=https://passport.et

# Site name (appears in page titles, meta tags)
VITE_SITE_NAME=Passport
VITE_ENABLE_CRITICAL_CSS=true

# Horizon URL (Laravel Horizon dashboard, optional)
# VITE_HORIZON_URL=https://api.passport.et/horizon

# ==============================================
# ChatGPT App Deployment (Docker Compose)
# ==============================================
# Public API origin used by the MCP server
PASSPORT_API_BASE_URL=https://api.passport.et

# Public site origin used in result links
PASSPORT_SITE_URL=https://passport.et

# Internal MCP server port inside Docker
CHATGPT_APP_PORT=8787

# MCP path exposed by the app
CHATGPT_MCP_PATH=/mcp

# Submission-ready widget domain, if you have a dedicated host for the ChatGPT app
# Example: https://chatgpt.passport.et
CHATGPT_WIDGET_DOMAIN=https://chatgpt.passport.et

# ==============================================
# Umami Analytics (Docker Compose)
# ==============================================

# PostgreSQL credentials for Umami database
POSTGRES_DB=umami
POSTGRES_USER=umami
POSTGRES_PASSWORD=change-this-to-a-strong-password

# Umami application secrets (generate random hex strings)
# Generate with: openssl rand -hex 32
UMAMI_APP_SECRET=change-this-to-random-hex-64-chars
UMAMI_HASH_SALT=change-this-to-random-hex-32-chars

# Umami database URL (constructed from above)
DATABASE_URL=postgresql://umami:change-this-to-a-strong-password@umami-db:5432/umami

# ==============================================
# Deployment (GitHub Actions Secrets)
# ==============================================
# Add these as repository secrets in GitHub:
# - DEPLOY_HOST: Server IP or hostname
# - DEPLOY_USER: SSH user with Docker permissions
# - DEPLOY_SSH_KEY: Private SSH key for authentication
# - DEPLOY_PORT: SSH port (default: 22)
